{
  "name": "@yayoi-next-bridge/chrome-extension",
  "version": "0.1.0",
  "description": "弥生給与NEXT → 弥生会計NEXT データ変換 Chrome拡張",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "encoding-japanese": "^2.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@crxjs/vite-plugin": "^2.4.0",
    "@types/chrome": "^0.1.40",
    "@types/encoding-japanese": "^2.2.1",
    "@vitest/coverage-v8": "^4.1.3",
    "@vitest/ui": "^4.1.3",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.3"
  },
  "private": true
}
