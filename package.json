{
  "name": "yayoi-next-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "弥生給与NEXT → 弥生会計NEXT データ変換ツール",
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "prepare": "lefthook install",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test -- --run",
    "test:coverage": "pnpm -r run test:coverage -- --run",
    "build": "pnpm -r run build",
    "version:check": "node scripts/bump-version.js",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major",
    "release": "node scripts/release.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scottlz0310/yayoi-next-bridge.git"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "lefthook": "^2.1.8"
  }
}
